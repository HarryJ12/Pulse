NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Use your public anon JWT or Supabase publishable key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-public-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-if-needed-server-only
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PULSE_ACCESS_PASSWORD=your-shared-cohort-password

# Configure these in Supabase Auth > Providers > GitHub.
# They are documented here for setup only and are not used by the Next.js app.
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
